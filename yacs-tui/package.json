{
  "name": "yacs-tui",
  "version": "1.0.0",
  "description": "Yet Another Cloud Service - Terminal User Interface",
  "main": "dist/index.js",
  "bin": {
    "yacs": "dist/index.js"
  },
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "postbuild": "npm install -g . && echo \"export PATH=\\\"$(npm config get prefix)/bin:\\$PATH\\\"\" >> ~/.x",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test-project-create": "npm run dev -- project create test-project",
    "test-project-list": "npm run dev -- project list",
    "test-help": "npm run dev -- --help"
  },
  "keywords": [
    "cli",
    "typescript",
    "cloud"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  },
  "dependencies": {}
}
