{
  "name": "@yacs/tui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "bun build src/index.tsx --outdir dist --target node",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "start": "node dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opentui/core": "latest",
    "@opentui/react": "latest",
    "@yacs/schemas": "*",
    "react": ">=19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "eslint": "^9.8.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "globals": "^15.11.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.0.0"
  }
}
