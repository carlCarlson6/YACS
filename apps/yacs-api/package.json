{
  "name": "@yacs/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@yacs/schemas": "*",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.16.3",
    "@azure/storage-blob": "^12.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.15.5",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
